# WaferVision v0.9 production-oriented runtime
WAFERVISION_ENVIRONMENT=local
WAFERVISION_CHECKPOINT_PATH=artifacts/checkpoints/wafer_cnn_best.pt
WAFERVISION_MODEL_KIND=auto
WAFERVISION_DEVICE=auto
WAFERVISION_TOP_K=5

# v0.9 default: Postgres owns durable state.
WAFERVISION_DATABASE_URL=postgresql+psycopg://wafervision:wafervision@localhost:5432/wafervision
WAFERVISION_DB_POOL_SIZE=5
WAFERVISION_DB_MAX_OVERFLOW=10

# Redis backs RQ/Celery transport and distributed rate limiting.
WAFERVISION_REDIS_URL=redis://localhost:6379/0
WAFERVISION_REDIS_KEY_PREFIX=wafervision

# Queue backend: rq is the recommended default. celery and temporal are optional adapters.
WAFERVISION_JOB_BACKEND=rq
WAFERVISION_JOB_QUEUE_NAME=wafervision-simulator
WAFERVISION_JOB_TIMEOUT_SECONDS=900
WAFERVISION_JOB_RESULT_TTL_SECONDS=3600
WAFERVISION_JOB_FAILURE_TTL_SECONDS=86400
# false keeps polling payloads small. Frontend fetches persisted session by session_id.
WAFERVISION_JOB_POLL_PERSIST_RESULTS=false

# Celery optional adapter
WAFERVISION_CELERY_BROKER_URL=redis://localhost:6379/0
WAFERVISION_CELERY_RESULT_BACKEND=redis://localhost:6379/0
WAFERVISION_CELERY_QUEUE_NAME=wafervision-simulator

# Temporal optional adapter
WAFERVISION_TEMPORAL_ADDRESS=localhost:7233
WAFERVISION_TEMPORAL_NAMESPACE=default
WAFERVISION_TEMPORAL_TASK_QUEUE=wafervision-simulator

WAFERVISION_MAX_UPLOAD_MB=10
WAFERVISION_CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000

# Optional enterprise guardrails. Leave API key empty for local demo mode.
# WAFERVISION_API_KEY=change-me
WAFERVISION_RATE_LIMIT_ENABLED=true
WAFERVISION_RATE_LIMIT_BACKEND=redis
WAFERVISION_RATE_LIMIT_FAIL_OPEN=true
WAFERVISION_RATE_LIMIT_WINDOW_SECONDS=60
WAFERVISION_RATE_LIMIT_REQUESTS=240
WAFERVISION_SIMULATOR_RATE_LIMIT_REQUESTS=45

# Simulator persistence guardrails: save compact session rows instead of huge JSON blobs.
WAFERVISION_SIMULATOR_MAX_PERSIST_WAFERS=240
WAFERVISION_SIMULATOR_PERSIST_MATRIX_SIZE=40
WAFERVISION_SIMULATOR_PERSIST_DOWNSAMPLE_METHOD=area
WAFERVISION_SIMULATOR_PERSIST_MATRICES=false
WAFERVISION_SIMULATOR_MODEL_BATCH_SIZE=128

# Simulator execution analytics. Raw IPs are not stored; only salted SHA-256 hashes.
WAFERVISION_SIMULATION_RUN_LOGGING_ENABLED=true
WAFERVISION_SIMULATION_LOG_IP_SALT=replace-with-a-long-random-secret

# Offline laptop/test fallback:
# WAFERVISION_DATABASE_URL=sqlite:///./data/runtime/wafervision.db
# WAFERVISION_JOB_BACKEND=inline
# WAFERVISION_RATE_LIMIT_BACKEND=memory
