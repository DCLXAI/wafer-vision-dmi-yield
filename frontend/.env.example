# Week 2 FastAPI backend. Both forms are accepted:
#   http://localhost:8000
#   http://localhost:8000/api/v1
VITE_API_BASE_URL=http://localhost:8000

# true = frontend-only portfolio demo using browser mock predictions/history.
# false = call the real FastAPI backend from Week 2.
VITE_USE_MOCKS=true

# Backward-compatible alias also supported by src/api.ts:
# VITE_DEMO_MODE=true

VITE_API_TIMEOUT_MS=15000

# Optional: when backend WAFERVISION_API_KEY is set, pass it here for protected API calls.
# Do not put production secrets into a public static frontend build.
VITE_API_KEY=

# Public deployment notes:
# - For a portfolio/demo-only website, keep VITE_USE_MOCKS=true.
# - For a live backend, set VITE_USE_MOCKS=false and use an HTTPS API URL.
# - VITE_* values are embedded into the browser bundle; do not place private secrets here.
